services:
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"

  minio:
    image: minio/minio:latest
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin
    ports:
      - "9000:9000"   # S3 API
      - "9001:9001"   # console UI
    volumes:
      - ./.minio:/data

  createbuckets:
    image: minio/mc:latest
    depends_on:
      - minio
    entrypoint: >
      /bin/sh -c "
      sleep 2;
      mc alias set local http://minio:9000 minioadmin minioadmin;
      mc mb -p local/metaflow || true;
      mc mb -p local/artifacts || true;
      mc mb -p local/reports || true;
      exit 0;
      "

  api:
    build:
      context: .
      dockerfile: docker/Dockerfile.api
    environment:
      REDIS_URL: "redis://redis:6379/0"

      # Local S3 (MinIO) - for artifact versioning demos
      S3_ENDPOINT_URL: "http://minio:9000"
      AWS_ACCESS_KEY_ID: "minioadmin"
      AWS_SECRET_ACCESS_KEY: "minioadmin"
      AWS_DEFAULT_REGION: "us-east-1"
      S3_BUCKET: "artifacts"

    ports:
      - "8000:8000"
    depends_on:
      - redis
      - createbuckets

    # CRITICAL: mount your real data/artifacts/reports so API doesn't crash on missing files
    volumes:
      - ./data:/app/data
      - ./artifacts:/app/artifacts
      - ./reports:/app/reports

  dashboard:
    build:
      context: .
      dockerfile: docker/Dockerfile.dashboard
    ports:
      - "8501:8501"
    depends_on:
      - api
    volumes:
      - ./reports:/app/reports
      - ./artifacts:/app/artifacts
