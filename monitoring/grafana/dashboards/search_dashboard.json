{
  "id": null,
  "uid": "streaming-canvas-search",
  "title": "Streaming Canvas Search — Production Dashboard",
  "tags": ["search", "ltr", "netflix"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(api_requests_total{path='/search'}[1m]))",
        "legendFormat": "req/s"
      }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } }
    },
    {
      "id": 2,
      "title": "p50 Latency (ms)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.50, rate(api_request_latency_ms_bucket{path='/search'}[5m]))",
        "legendFormat": "p50"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 }] } } }
    },
    {
      "id": 3,
      "title": "p95 Latency (ms)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(api_request_latency_ms_bucket{path='/search'}[5m]))",
        "legendFormat": "p95"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 300 }] } } }
    },
    {
      "id": 4,
      "title": "p99 Latency (ms)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(api_request_latency_ms_bucket{path='/search'}[5m]))",
        "legendFormat": "p99"
      }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 400 }, { "color": "red", "value": 600 }] } } }
    },
    {
      "id": 5,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "100 * sum(rate(api_requests_total{status=~'5..'}[5m])) / sum(rate(api_requests_total[5m]))",
        "legendFormat": "error %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] } } }
    },
    {
      "id": 6,
      "title": "Cache Hit Rate (%)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "100 * sum(rate(api_requests_total{path='/search',status='200'}[5m])) / (sum(rate(api_requests_total{path='/search'}[5m])) + 0.001)",
        "legendFormat": "cache hit %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] } } }
    },
    {
      "id": 7,
      "title": "Request Latency Distribution",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(api_request_latency_ms_bucket{path='/search'}[2m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(api_request_latency_ms_bucket{path='/search'}[2m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(api_request_latency_ms_bucket{path='/search'}[2m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineInterpolation": "smooth" } } },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "title": "Requests by Method",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "targets": [
        { "expr": "sum by (path) (rate(api_requests_total[2m]))", "legendFormat": "{{ path }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9,
      "title": "HTTP Status Codes",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [
        { "expr": "sum by (status) (rate(api_requests_total[2m]))", "legendFormat": "HTTP {{ status }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 10,
      "title": "Answer Endpoint Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(api_request_latency_ms_bucket{path='/answer'}[5m]))", "legendFormat": "p50 /answer" },
        { "expr": "histogram_quantile(0.95, rate(api_request_latency_ms_bucket{path='/answer'}[5m]))", "legendFormat": "p95 /answer" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ]
}
