# ─── App Config ──────────────────────────────────────────────────────────────
# Which dataset config to load (movielens or nfcorpus)
APP_CONFIG=config/app.yaml

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Cache TTLs (seconds)
SEARCH_CACHE_TTL=600
ANSWER_CACHE_TTL=1800

# ─── Ollama (GenAI / RAG) ────────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest

# ─── Metaflow / MinIO artifact store ─────────────────────────────────────────
METAFLOW_DEFAULT_DATASTORE=s3
METAFLOW_DEFAULT_METADATA=service
METAFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
METAFLOW_DATASTORE_SYSROOT_S3=s3://metaflow

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=searchltr2026

# ─── PyTorch thread caps (prevents CPU contention under concurrency) ──────────
TORCH_NUM_THREADS=1
TORCH_NUM_INTEROP_THREADS=1
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
