@app.get("/tts", include_in_schema=False)
async def tts(
    text: str = Query(..., min_length=1, max_length=800),
    lang: str = Query("", description="Preferred language name (e.g., Tamil)"),
    language: str = Query("", description="Alias for lang (UI compatibility)"),
) -> Response:
    want = (lang or language or "English").strip()
    voice = VOICE_MAP.get(want, VOICE_MAP.get("English", "en-US-JennyNeural"))

    try:
        import edge_tts  # type: ignore
    except Exception as err:
        raise HTTPException(
            status_code=503,
            detail="edge-tts not installed. Run: uv add edge-tts",
        ) from err

    text2 = text.strip()
    if len(text2) > 420:
        text2 = text2[:420] + "."

    async def synth(v: str) -> bytes:
        communicate = edge_tts.Communicate(text=text2, voice=v)
        audio_parts: list[bytes] = []
        async for chunk in communicate.stream():
            if chunk.get("type") == "audio":
                audio_parts.append(chunk["data"])
        return b"".join(audio_parts)

    used_voice = voice
    used_lang = want
    try:
        audio = await synth(voice)
        if not audio:
            raise RuntimeError("empty audio")
    except Exception:
        used_voice = VOICE_MAP.get("English", "en-US-JennyNeural")
        used_lang = "English"
        audio = await synth(used_voice)

    headers = {"X-TTS-Voice": used_voice, "X-TTS-Lang": used_lang}
    return Response(content=audio, media_type="audio/mpeg", headers=headers)
