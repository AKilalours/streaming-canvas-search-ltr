# /explain (grounded + agentic option)
# -----------------------------
@app.get("/explain")
def explain(
    doc_id: str,
    profile: str = "chrisen",
    language: str = "English",
    agentic: bool = False,
) -> dict[str, Any]:
    st = _ensure_ready()
    ollama = _ensure_ollama()

    row = st.corpus.get(str(doc_id))
    if not row:
        raise HTTPException(status_code=404, detail="doc_id not found")

    title = str(row.get("title") or "Unknown")
    text = str(row.get("text") or "")
    lang_tag = _lang_for_doc_id(str(doc_id))

    profile_prefs = {
        "chrisen": "likes high-energy action, crime thrillers, and mind-bending sci-fi",
        "gilbert": "likes feel-good romance, romantic comedy, family-friendly titles",
    }.get(profile.lower(), "likes a mix of popular titles")

    srcs = [
        Source(
            doc_id=str(doc_id),
            title=title,
            snippet=_snippet(text, 800) or text,
            score=None,
            score_breakdown=None,
        )
    ]
    context = f"[1] doc_id={doc_id}\nTITLE: {title}\nTEXT: {srcs[0].snippet}\n"

    question = (
        "Explain why this title fits the user in a Netflix-style way. "
        f"User profile '{profile}' {profile_prefs}. "
        f"User selected language: {language}. Title language tag: {lang_tag}. "
        "Return: (1) one-sentence reason, (2) one-sentence synopsis. Cite [1]."
    )

    if not agentic:
        prompt = rag_prompt(question, context=context)
        llm_out = _ollama_json(ollama, prompt=prompt, schema=output_schema(), temperature=0.2, top_p=0.9)
        answer_text, citations, warn = _validate_llm_output(llm_out, num_sources=len(srcs))

        answer_text2, _ = _maybe_translate_answer(ollama, answer_text, language)
        return {
            "doc_id": doc_id,
            "profile": profile,
            "language": language,
            "answer": answer_text2,
            "citations": citations,
            "warning": warn,
            "sources": [s.model_dump() for s in srcs],
        }

    # Agentic version (still grounded to the single item)
    def search_fn(payload: dict[str, Any]) -> dict[str, Any]:
        return {"hits": [{"doc_id": doc_id, "title": title, "text": text, "score": 1.0}]}

    def build_context_fn(hits: list[Any]) -> str:
        return context

    def sources_fn(hits: list[Any]) -> list[dict[str, Any]]:
        return [srcs[0].model_dump()]

    payload, trace = run_agentic_rag(
        ollama=ollama,
        query=question,
        method="hybrid_ltr",
        k=1,
        initial_candidate_k=1,
        initial_context_k=1,
        alpha=0.5,
        rerank_k=1,
        max_steps=2,
        search_fn=search_fn,
        build_context_fn=build_context_fn,
        sources_fn=sources_fn,
        temperature=0.0,
        top_p=0.9,
    )

    warning = payload.get("warning")
    if trace and trace[-1].supported is False and trace[-1].reason is not None:
        warning = warning or trace[-1].reason

    ans = str(payload.get("answer", ""))
    ans2, _ = _maybe_translate_answer(ollama, ans, language)

    return {
        "doc_id": doc_id,
        "profile": profile,
        "language": language,
        "answer": ans2,
        "warning": warning,
        "agent_steps": len(trace),
        "sources": [s.model_dump() for s in srcs],
    }


